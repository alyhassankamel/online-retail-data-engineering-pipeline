                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
    LTRIM(RTRIM(s.Country)) AS CountryName
FROM STG_OnlineRetail s
WHERE s.Country IS NOT NULL
  AND LTRIM(RTRIM(s.Country)) &lt;&gt; ''
  AND NOT EXISTS (
      SELECT 1
      FROM DIM_COUNTRY d
      WHERE d.CountryName = LTRIM(RTRIM(s.Country))
  )</property>
