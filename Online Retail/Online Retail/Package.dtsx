            <component
              refId="Package\Dimention Tables To Fact Table\Dimensions"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="Dimensions"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    LTRIM(RTRIM(s.Invoice)) AS InvoiceNo,
    LTRIM(RTRIM(s.StockCode)) AS StockCode,
    TRY_CAST(s.CustomerID AS INT) AS CustomerID,
    CONVERT(INT, FORMAT(TRY_CAST(s.InvoiceDate AS DATE), 'yyyyMMdd')) AS DateID,
    LTRIM(RTRIM(s.Country)) AS CountryName,
    SUM(s.Quantity) AS Quantity,
    MAX(s.Price) AS UnitPrice
FROM STG_OnlineRetail s
WHERE s.Invoice IS NOT NULL
  AND s.CustomerID IS NOT NULL
  AND TRY_CAST(s.CustomerID AS INT) IS NOT NULL
  AND s.Quantity &gt; 0
  AND s.Price &gt; 0
  AND TRY_CAST(s.InvoiceDate AS DATETIME) IS NOT NULL
  AND LEFT(LTRIM(RTRIM(s.Invoice)), 1) &lt;&gt; 'C'
  AND NOT EXISTS (
      SELECT 1
      FROM FACT_SALES f
      WHERE f.InvoiceNo = LTRIM(RTRIM(s.Invoice))
        AND f.CustomerID = TRY_CAST(s.CustomerID AS INT)
        AND f.DateID = CONVERT(INT, FORMAT(TRY_CAST(s.InvoiceDate AS DATE), 'yyyyMMdd'))
  )
GROUP BY
    LTRIM(RTRIM(s.Invoice)),
    LTRIM(RTRIM(s.StockCode)),
    TRY_CAST(s.CustomerID AS INT),
    CONVERT(INT, FORMAT(TRY_CAST(s.InvoiceDate AS DATE), 'yyyyMMdd')),
    LTRIM(RTRIM(s.Country))</property>
                <property
